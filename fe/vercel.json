{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://past-forward-production.up.railway.app/api/:path*" },
    { "source": "/outputs/:path*", "destination": "https://past-forward-production.up.railway.app/outputs/:path*" },
    { "source": "/overlay-inspection", "destination": "/overlay-inspection.html" }
  ]
}
