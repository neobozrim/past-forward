# Past Forward environment
#
# Copy this file to `.env`, replace every placeholder, and keep `.env` private.
# The application is started with:
#   python -m sofia_harness.system_cli serve --port 8000
# Port selection is a CLI option, not an environment variable.

# Comma-separated browser origins allowed to call this Railway API.
# Add both the production Vercel URL and any custom frontend domain.
PAST_FORWARD_FRONTEND_URLS=http://localhost:5173,https://your-app.vercel.app
PAST_FORWARD_PROJECT_ROOT=

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------

# Server-side secret used for AI-generated archive answers and digitization.
# Never expose this value in browser code or commit it to Git.
OPENAI_API_KEY=sk-your-openai-api-key

# Enables paid digitization and agent execution through the hosted application.
# Set to false if judges should only use the prepared archive.
PAST_FORWARD_API_ENABLED=true

# Enables GPT-generated, evidence-backed answers over retrieved archive records.
# Plain archive retrieval remains available when this is false.
PAST_FORWARD_SEARCH_ANSWERS_ENABLED=true

# Optional path to the rebuildable SQLite archive search index.
PAST_FORWARD_SEARCH_DB=search_data/index/archive.db

# -----------------------------------------------------------------------------
# Braintrust tracing
# -----------------------------------------------------------------------------

# Set this secret in the cloud deployment environment to enable search traces.
BRAINTRUST_API_KEY=
BRAINTRUST_API_URL=https://api.braintrust.dev
BRAINTRUST_APP_URL=https://www.braintrust.dev
BRAINTRUST_ORG_ID=1c4ab56b-1083-402c-a797-97277730c0c8
BRAINTRUST_PROJECT_ID=1ceada4e-d99a-4aa9-9d69-682187c7f6d0

# -----------------------------------------------------------------------------
# Supabase Auth
# -----------------------------------------------------------------------------

# Find both values in Supabase Dashboard -> Project Settings -> API Keys.
SUPABASE_URL=https://your-project-ref.supabase.co

# Current public browser key. It normally begins with `sb_publishable_`.
# Do not use a legacy anon key, `sb_secret_` key, or service-role key here.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-public-key

# Requires a valid Supabase session for archive APIs, generated outputs,
# digitization endpoints, and Overlay Inspection.
PAST_FORWARD_AUTH_REQUIRED=true

# Comma-separated Supabase account emails allowed to operate digitization.
# Authorization is enforced by the backend after validating the access token.
PAST_FORWARD_ADMIN_EMAILS=admin@example.com

# Shows the hero landing screen. When authentication is disabled, visitors see
# a simple Enter Past Forward button instead of sign-in controls.
PAST_FORWARD_LANDING_ENABLED=true

# No Redis configuration is required. Past Forward currently uses filesystem
# checkpoints plus a local SQLite search index.
